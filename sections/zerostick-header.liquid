{%- comment -%} ZeroStick two-row navbar (matches netlify site) {%- endcomment -%}
<header class="site-header">

  <div class="announce-bar">
    EVERY CONTROLLER EQUIPPED WITH <strong>TMR TECHNOLOGY</strong> AND A <strong>5-YEAR STICK WARRANTY</strong>
  </div>

  <div class="nav-top">
    <div class="nav-top-inner">
      <button class="nav-burger" aria-label="Menu" onclick="document.body.classList.toggle('zs-menu-open')">&#9776;</button>
      <a class="nav-logo" href="/"><img src="{{ 'zerostick-logo.png' | asset_url }}" alt="ZeroStick" /></a>
      <div class="nav-search">
        <span class="nav-search-icon">&#128269;</span>
        <form action="/search" method="get" style="width:100%">
          <input type="search" name="q" id="zs-search-input" placeholder="Search products..." />
        </form>
      </div>
      <div class="nav-actions">
        <a href="/account/login" class="nav-icon-btn" title="Account">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        </a>
        <a href="/cart" class="nav-icon-btn" title="Cart">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        </a>
      </div>
    </div>
  </div>

  <nav class="nav-bottom">
    <div class="nav-bottom-inner">
      <ul class="nav-links">
        <li>
          <a href="/collections/all">PS5 <span class="caret">&#9662;</span></a>
          <div class="dropdown">
            <div class="drop-label">Shop</div>
            <a href="/pages/builder">Controller Designer</a>
            <a href="/collections/all">Quick Picks</a>
            <a href="/collections/all">Pre-Builts</a>
          </div>
        </li>
        <li>
          <a href="/collections/all">Modules <span class="caret">&#9662;</span></a>
          <div class="dropdown">
            <a href="/collections/all">TMR Modules</a>
            <a href="/collections/all">DualSense Edge</a>
            <a href="/collections/all">Mail-In Service</a>
          </div>
        </li>
        <li><a href="/collections/all">Shop All <span class="caret">&#9662;</span></a></li>
        <li><a href="/pages/builder">3D Builder <span class="caret">&#9662;</span></a></li>
      </ul>
      <div class="nav-info">
        <a href="/pages/contact">Contact Us</a>
        <a href="/pages/contact" class="btn-support">&#128100; Support &amp; FAQ</a>
      </div>
    </div>
  </nav>

  <!-- Mobile menu (revealed by hamburger) -->
  <div class="zs-mobile-menu">
    <a href="/collections/all">PS5 Controllers</a>
    <a href="/collections/all">TMR Modules</a>
    <a href="/collections/all">Shop All</a>
    <a href="/pages/builder">3D Builder</a>
    <a href="/pages/contact">Contact Us</a>
    <a href="/pages/contact">Support &amp; FAQ</a>
    <a href="/account/login">Account</a>
    <a href="/cart">Cart</a>
  </div>

  <script>
    (function(){
      var input = document.getElementById('zs-search-input');
      if (!input) return;
      var words = ['PS5 Controller', 'DualSense Edge Module', 'TMR Hall-Effect Module', 'Switch Pro Controller', 'Smart Triggers', 'Rear Buttons'];
      var wi = 0, ci = 0, deleting = false, paused = false;
      function tick(){
        // stop animating once the user interacts
        if (document.activeElement === input || input.value) { input.setAttribute('placeholder','Search products...'); setTimeout(tick, 1000); return; }
        var w = words[wi];
        if (!deleting) {
          ci++;
          input.setAttribute('placeholder', 'Search "' + w.substring(0, ci) + '"');
          if (ci >= w.length) { deleting = true; setTimeout(tick, 1400); return; }
          setTimeout(tick, 95);
        } else {
          ci--;
          input.setAttribute('placeholder', 'Search "' + w.substring(0, ci) + '"');
          if (ci <= 0) { deleting = false; wi = (wi + 1) % words.length; setTimeout(tick, 350); return; }
          setTimeout(tick, 45);
        }
      }
      tick();
    })();
  </script>
</header>

{% schema %}
{
  "name": "ZeroStick Header",
  "settings": []
}
{% endschema %}
